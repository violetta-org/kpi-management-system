{
  "mcpServers": {
    "canvas-authoring": {
      "command": "dotnet",
      "args": [
        "dnx",
        "Microsoft.PowerApps.CanvasAuthoring.McpServer",
        "--yes",
        "--prerelease",
        "--source",
        "https://api.nuget.org/v3/index.json"
      ],
      "env": {
        "CANVAS_ENVIRONMENT_ID": "84534e74-80d5-e347-ade4-4236f035288a",
        "CANVAS_APP_ID": "1ab4ac12-b2e4-4db9-9a88-8f65641cf313",
        "CANVAS_CLUSTER_CATEGORY": "prod"
      }
    },
    "powerplatform": {
      "command": "npx",
      "args": [
        "-y",
        "powerplatform-mcp"
      ]
    },
    "powerbi": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/powerbi-modeling-mcp"
      ]
    }
  }
}